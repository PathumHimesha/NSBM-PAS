@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        color: #2b3445;
        min-height: 100vh;
        margin: 0;
        position: relative;
    }

    body::before {
        content: "";
        position: fixed;
        top: 0; left: 0; width: 100vw; height: 100vh;
        background: url('https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2069&auto=format&fit=crop') no-repeat center center;
        background-size: cover;
        filter: blur(12px) brightness(0.35);
        z-index: -1;
    }

    .page-title { font-weight: 800; color: #ffffff; letter-spacing: -0.5px; text-shadow: 0 4px 10px rgba(0, 0, 0, 0.5); }
    .page-subtitle { color: #cbd5e1; font-weight: 500; text-shadow: 0 2px 5px rgba(0, 0, 0, 0.5); }

    .smooth-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        padding: 2rem;
        backdrop-filter: blur(5px);
    }
    .smooth-card:hover { transform: translateY(-4px); box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5); }

    .card-heading {
        font-size: 1.25rem; font-weight: 700; color: #1e293b;
        margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 2px solid #e2e8f0;
    }

    .input-soft {
        background-color: #f1f5f9; border: 1px solid transparent; border-radius: 12px;
        padding: 0.8rem 1.2rem; font-size: 0.95rem; color: #1e293b; transition: all 0.2s ease;
    }
    .input-soft:focus { background-color: #ffffff; border-color: #94a3b8; box-shadow: 0 0 0 4px rgba(226, 236, 249, 0.8); outline: none; }

    .btn-smooth-primary {
        background-color: #3b82f6; color: white; border: none; border-radius: 12px;
        padding: 0.8rem 1.5rem; font-weight: 600; transition: all 0.2s ease;
    }
    .btn-smooth-primary:hover { background-color: #2563eb; color: white; transform: translateY(-2px); }

    .btn-smooth-danger {
        background-color: transparent; color: #ef4444; border: 1px solid #ef4444;
        border-radius: 8px; font-weight: 600; font-size: 0.85rem; padding: 0.4rem 1rem; transition: all 0.2s ease;
    }
    .btn-smooth-danger:hover { background-color: #ef4444; color: white; }

    /* ALUTH: Edit Button Styling */
    .btn-smooth-edit {
        background-color: transparent; color: #3b82f6; border: 1px solid #3b82f6;
        border-radius: 8px; font-weight: 600; font-size: 0.85rem; padding: 0.4rem 1rem; transition: all 0.2s ease;
    }
    .btn-smooth-edit:hover { background-color: #3b82f6; color: white; }

    .list-group-item-smooth {
        background: transparent; border: none; border-bottom: 1px solid #e2e8f0;
        padding: 1.2rem 0.5rem; transition: background-color 0.2s;
    }
    .list-group-item-smooth:last-child { border-bottom: none; }
    .list-group-item-smooth:hover { background-color: #f8fafc; border-radius: 12px; padding-left: 1rem; padding-right: 1rem; }

    .badge-soft {
        background-color: #f1f5f9; color: #475569; padding: 0.5em 1em;
        border-radius: 8px; font-weight: 600; font-size: 0.8rem;
    }
    
    /* Modal Styling */
    .modal-content { border-radius: 20px; border: none; }

    /* ALUTH: Modal backdrop fix */
.modal-backdrop {
    z-index: 1040 !important;
}
.modal {
    z-index: 1050 !important;
    background: rgba(0, 0, 0, 0.5); /* Modal eka pitipasse thiyena dark gathiya lassanata hadamu */
}

/* Modal eka athule thiyena input boxes white background ekata gannawa touch karanna lesi wenna */
.modal-content .input-soft {
    background-color: #ffffff !important;
    border: 1px solid #e2e8f0 !important;
}
</style>

<div class="container mt-5 mb-5" style="position: relative; z-index: 1;">
    
    <div class="mb-5 text-center">
        <h1 class="page-title">Module Leader Portal</h1>
        <p class="page-subtitle">Manage user access and system registration</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 rounded-3 shadow-sm mb-4" style="background-color: #fee2e2; color: #991b1b;">
            <strong>Notice:</strong> @TempData["Error"]
        </div>
    }

    <div class="row g-4">
        <div class="col-md-6">
            <div class="smooth-card h-100">
                <h4 class="card-heading">Student Management</h4>
                
                <form asp-action="AddStudent" method="post" class="mb-4">
                    <div class="d-flex flex-column flex-md-row gap-2 mb-4">
                        <input type="text" name="name" class="form-control input-soft flex-grow-1" placeholder="Full Name" required>
                        <input type="email" name="email" class="form-control input-soft flex-grow-1" placeholder="Email Address" required>
                        <button class="btn btn-smooth-primary px-4" type="submit">Register</button>
                    </div>
                </form>

                <h6 class="text-muted fw-bold mb-3 small text-uppercase" style="letter-spacing: 1px;">Active Students</h6>
                
                <div style="max-height: 400px; overflow-y: auto; overflow-x: hidden; padding-right: 5px;">
                    <ul class="list-group list-group-flush">
                        @if (ViewBag.Students != null)
                        {
                            foreach (var student in ViewBag.Students)
                            {
                                <li class="list-group-item-smooth d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong style="color: #0f172a; font-size: 1.05rem;">@student.Name</strong> <br> 
                                        <small style="color: #64748b;">@student.Email</small>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge-soft me-2">ID: @student.StudentId</span>
                                        
                                        <button type="button" class="btn btn-smooth-edit" data-bs-toggle="modal" data-bs-target="#editStudentModal" 
                                                data-id="@student.StudentId" data-name="@student.Name" data-email="@student.Email">Edit</button>
                                        
                                        <form asp-action="DeleteStudent" asp-route-id="@student.StudentId" method="post" onsubmit="return confirm('Remove @student.Name from the system?');" class="m-0">
                                            <button type="submit" class="btn btn-smooth-danger">Remove</button>
                                        </form>
                                    </div>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="smooth-card h-100">
                <h4 class="card-heading">Supervisor Management</h4>
                
                <form asp-action="AddSupervisor" method="post" class="mb-4">
                    <div class="d-flex flex-column flex-md-row gap-2 mb-4">
                        <input type="text" name="name" class="form-control input-soft flex-grow-1" placeholder="Full Name" required>
                        <input type="email" name="email" class="form-control input-soft flex-grow-1" placeholder="Email Address" required>
                        <button class="btn btn-smooth-primary px-4" type="submit">Register</button>
                    </div>
                </form>

                <h6 class="text-muted fw-bold mb-3 small text-uppercase" style="letter-spacing: 1px;">Active Supervisors</h6>
                
                <div style="max-height: 400px; overflow-y: auto; overflow-x: hidden; padding-right: 5px;">
                    <ul class="list-group list-group-flush">
                        @if (ViewBag.Supervisors != null)
                        {
                            foreach (var sup in ViewBag.Supervisors)
                            {
                                <li class="list-group-item-smooth d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong style="color: #0f172a; font-size: 1.05rem;">@sup.Name</strong><br> 
                                        <small style="color: #64748b;">@sup.Email</small>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge-soft me-2">ID: @sup.SupervisorId</span>
                                        
                                        <button type="button" class="btn btn-smooth-edit" data-bs-toggle="modal" data-bs-target="#editSupervisorModal" 
                                                data-id="@sup.SupervisorId" data-name="@sup.Name" data-email="@sup.Email">Edit</button>

                                        <form asp-action="DeleteSupervisor" asp-route-id="@sup.SupervisorId" method="post" onsubmit="return confirm('Remove @sup.Name from the system?');" class="m-0">
                                            <button type="submit" class="btn btn-smooth-danger">Remove</button>
                                        </form>
                                    </div>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editStudentModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content smooth-card" style="padding: 1.5rem; background: rgba(255,255,255,0.98);">
      <div class="modal-header border-0 p-0 mb-4">
        <h5 class="modal-title card-heading m-0 border-0 pb-0">Edit Student Info</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form asp-action="EditStudent" method="post">
        <input type="hidden" name="id" id="editStudentId" />
        <div class="modal-body p-0 mb-4">
          <div class="form-group mb-4">
            <label class="text-muted fw-bold small mb-2 text-uppercase">Full Name</label>
            <input type="text" name="name" id="editStudentName" class="form-control input-soft" required />
          </div>
          <div class="form-group">
            <label class="text-muted fw-bold small mb-2 text-uppercase">Email Address</label>
            <input type="email" name="email" id="editStudentEmail" class="form-control input-soft" required />
          </div>
        </div>
        <div class="modal-footer border-0 p-0 d-flex gap-2">
          <button type="button" class="btn btn-smooth-danger w-auto border-0 bg-light text-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-smooth-primary flex-grow-1">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="editSupervisorModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content smooth-card" style="padding: 1.5rem; background: rgba(255,255,255,0.98);">
      <div class="modal-header border-0 p-0 mb-4">
        <h5 class="modal-title card-heading m-0 border-0 pb-0">Edit Supervisor Info</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form asp-action="EditSupervisor" method="post">
        <input type="hidden" name="id" id="editSupervisorId" />
        <div class="modal-body p-0 mb-4">
          <div class="form-group mb-4">
            <label class="text-muted fw-bold small mb-2 text-uppercase">Full Name</label>
            <input type="text" name="name" id="editSupervisorName" class="form-control input-soft" required />
          </div>
          <div class="form-group">
            <label class="text-muted fw-bold small mb-2 text-uppercase">Email Address</label>
            <input type="email" name="email" id="editSupervisorEmail" class="form-control input-soft" required />
          </div>
        </div>
        <div class="modal-footer border-0 p-0 d-flex gap-2">
          <button type="button" class="btn btn-smooth-danger w-auto border-0 bg-light text-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-smooth-primary flex-grow-1">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        // ALUTH KALLA: Modal eka page animation eken eliyata gannawa (Backdrop issue fix)
        document.body.appendChild(document.getElementById('editStudentModal'));
        document.body.appendChild(document.getElementById('editSupervisorModal'));

        // Student Modal Data Load
        var editStudentModal = document.getElementById('editStudentModal');
        editStudentModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('editStudentId').value = button.getAttribute('data-id');
            document.getElementById('editStudentName').value = button.getAttribute('data-name');
            document.getElementById('editStudentEmail').value = button.getAttribute('data-email');
        });

        // Supervisor Modal Data Load
        var editSupervisorModal = document.getElementById('editSupervisorModal');
        editSupervisorModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('editSupervisorId').value = button.getAttribute('data-id');
            document.getElementById('editSupervisorName').value = button.getAttribute('data-name');
            document.getElementById('editSupervisorEmail').value = button.getAttribute('data-email');
        });
    </script>
}