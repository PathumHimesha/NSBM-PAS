@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    /* Login eke thibba styles ma thamai mekatath damma lassanata thiyenna */
    .login-container { min-height: 75vh; display: flex; align-items: center; justify-content: center; }
    .login-glass {
        background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);
        border-radius: 20px; border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 3.5rem 3rem; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3); width: 100%; max-width: 420px;
    }
    .input-premium {
        background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;
        padding: 1rem 1.2rem; font-size: 1rem; color: #1e293b; margin-bottom: 1.5rem; transition: all 0.2s ease;
    }
    .btn-login {
        background-color: #3b82f6; color: white; border: none; border-radius: 12px;
        padding: 1rem; font-weight: 700; width: 100%; letter-spacing: 1px; transition: all 0.3s ease;
    }
    .btn-login:hover { background-color: #2563eb; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(59,130,246,0.3); }
</style>

<div class="container login-container">
    <div class="login-glass text-center">
        <div class="mb-4 pb-2">
            <h3 class="fw-bold" style="color: #0f172a;">Reset Password</h3>
            <p class="text-muted small">Enter your email to receive a temporary password.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger text-start shadow-sm mb-4" style="border-radius: 10px; font-size: 0.9rem;">
                @TempData["Error"]
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div class="form-group text-start">
                <input type="email" name="email" class="form-control input-premium" placeholder="Enter your email" required />
            </div>

            <button type="submit" class="btn-login">SEND RESET LINK</button>
        </form>
        
        <div class="mt-4">
            <a asp-action="Login" class="text-secondary text-decoration-none small fw-bold">← Back to Login</a>
        </div>
    </div>
</div>