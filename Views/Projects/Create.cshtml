@model PAS_Project.Models.Project
@{
    ViewData["Title"] = "Submit Proposal";
}

<style>
    .form-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
        padding: 3.5rem;
        backdrop-filter: blur(10px);
        max-width: 800px;
        margin: 0 auto;
        animation: smoothFade 0.6s ease-in-out;
    }
    .form-title {
        color: #0f172a;
        font-weight: 800;
        font-size: 1.8rem;
        letter-spacing: -0.5px;
        margin-bottom: 2.5rem;
        border-bottom: 2px solid #f1f5f9;
        padding-bottom: 1rem;
    }
    .input-premium {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 1rem 1.2rem;
        font-size: 1rem;
        color: #1e293b;
        transition: all 0.2s ease;
    }
    .input-premium:focus {
        background-color: #ffffff;
        border-color: #3b82f6;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        outline: none;
    }
    
    /* ALUTH FILE BUTTON STYLING */
    .file-premium {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.5rem; 
        font-size: 0.95rem;
        color: #64748b;
        cursor: pointer;
    }
    .file-premium::file-selector-button {
        background-color: #f1f5f9;
        color: #0f172a;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 0.6rem 1.2rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        margin-right: 1rem;
    }
    .file-premium::file-selector-button:hover {
        background-color: #e2e8f0;
        color: #000000;
    }

    .form-label-custom {
        font-weight: 700;
        color: #475569;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }
    .btn-submit {
        background-color: #2563eb;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 0.8rem 2.5rem;
        font-weight: 600;
        transition: all 0.2s ease;
        letter-spacing: 0.5px;
    }
    .btn-submit:hover {
        background-color: #1d4ed8;
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(37, 99, 235, 0.3);
        color: white;
    }
    .btn-cancel {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 0.8rem 2rem;
        font-weight: 600;
        transition: all 0.2s ease;
    }
    .btn-cancel:hover {
        background-color: #e2e8f0;
        color: #0f172a;
    }
</style>

<div class="container mt-5 mb-5" style="position: relative; z-index: 1;">
    <div class="form-card">
        <h2 class="form-title">Submit Project Proposal</h2>
        
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="form-group mb-4">
                <label asp-for="Title" class="form-label-custom">Project Title</label>
                <input asp-for="Title" class="form-control input-premium" required />
            </div>
            
            <div class="form-group mb-4">
                <label asp-for="ResearchArea" class="form-label-custom">Research Area</label>
                <select asp-for="ResearchArea" class="form-select input-premium" required>
                    <option value="">-- Select a Research Area --</option>
                    @if(ViewBag.ResearchAreas != null)
                    {
                        @foreach (var area in ViewBag.ResearchAreas)
                        {
                            <option value="@area.Name">@area.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group mb-4">
                <label asp-for="TechnicalStack" class="form-label-custom">Technical Stack</label>
                <input asp-for="TechnicalStack" class="form-control input-premium" required />
            </div>

            <div class="form-group mb-4">
                <label asp-for="Abstract" class="form-label-custom">Project Abstract</label>
                <textarea asp-for="Abstract" class="form-control input-premium" rows="5" required></textarea>
            </div>

            <div class="form-group mb-5 p-4" style="background: #f8fafc; border: 2px dashed #cbd5e1; border-radius: 12px;">
                <label class="form-label-custom mb-3">Upload Proposal Document (Optional)</label>
                <input type="file" name="proposalFile" class="form-control file-premium" accept=".pdf,.doc,.docx" />
                <small class="text-muted mt-2 d-block">Accepted formats: PDF, Word (.doc, .docx)</small>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-submit">Submit Proposal</button>
                <a asp-action="Index" class="btn btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>